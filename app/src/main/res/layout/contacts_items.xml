<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/dark_purple_1"
    android:orientation="horizontal"
    android:padding="16dp">

    <ImageView
        android:id="@+id/emergency_ic"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/emergency_img"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_image"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:text="Ambulance"
        android:textColor="@color/white"
        android:textSize="20dp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/emergency_ic"
        app:layout_constraintStart_toEndOf="@id/emergency_ic"
        app:layout_constraintTop_toTopOf="@id/emergency_ic" />

    <ImageView
        android:id="@+id/phone_ic"
        android:layout_width="60px"
        android:layout_height="60px"
        android:clickable="true"
        android:focusable="true"
        android:src="@drawable/phone_ic"
        app:layout_constraintBottom_toBottomOf="@id/tv_image"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_image" />


</androidx.constraintlayout.widget.ConstraintLayout>